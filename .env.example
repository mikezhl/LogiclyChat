# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jileme?schema=public"

# ------------------------------------------------------------
# Credential source mode (false | true | full)
# false: only platform env keys, ignore all user-saved credentials
# true : user credentials override platform env per provider group
# full : only user credentials, never use platform env keys
# ------------------------------------------------------------
USER_PROVIDER_KEYS_MODE="true"

# ------------------------------------------------------------
# Room speaker switch feature flag
# false: one account speaks only as itself in a room
# true : allow toggling between username and usernameBot on one device
# ------------------------------------------------------------
ROOM_SPEAKER_SWITCH_ENABLED="false"

# ------------------------------------------------------------
# Platform default LiveKit credentials
# Required when USER_PROVIDER_KEYS_MODE is false/true
# ------------------------------------------------------------
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY="your_livekit_api_key"
LIVEKIT_API_SECRET="your_livekit_api_secret"

# ------------------------------------------------------------
# Transcriber worker controls
# ------------------------------------------------------------
LIVEKIT_TRANSCRIBER_ENABLED="true"
LIVEKIT_TRANSCRIBER_AGENT_NAME="deepgram-transcriber"
# Optional: auto-started dynamic worker idle recycle timeout (ms)
TRANSCRIBER_WORKER_IDLE_TIMEOUT_MS="600000"
# Optional: dynamic worker startup timeout before marking failure (ms)
TRANSCRIBER_WORKER_STARTUP_TIMEOUT_MS="30000"
# Optional: split transcript utterance after this much silence (ms)
TRANSCRIPT_UTTERANCE_GAP_MS="2000"

# ------------------------------------------------------------
# Conversation analysis worker controls
# ------------------------------------------------------------
# Polling interval for analysis-event queue
ANALYZER_QUEUE_POLL_INTERVAL_MS="1000"
# Realtime analysis trigger debounce after latest room message
ANALYZER_REALTIME_DEBOUNCE_MS="10000"
# Max pending events processed per polling cycle
ANALYZER_EVENT_BATCH_SIZE="200"
# Max compacted history turns included in realtime analysis payload
ANALYZER_HISTORY_TURN_LIMIT="18"
# Optional: analyzer worker startup timeout before marking failure (ms)
ANALYZER_WORKER_STARTUP_TIMEOUT_MS="30000"
# Optional: retry interval after schema-missing failure (ms)
ANALYZER_SCHEMA_RETRY_MS="60000"

# ------------------------------------------------------------
# Conversation LLM runtime (mock first)
# ------------------------------------------------------------
# mock | openai-compatible
CONVERSATION_LLM_PROVIDER="mock"
# prompt style key for realtime analysis mode
CONVERSATION_REALTIME_PROMPT_STYLE="default_cn"
# prompt style key for final summary mode
CONVERSATION_SUMMARY_PROMPT_STYLE="default_cn"

# ------------------------------------------------------------
# Platform default OpenAI-compatible LLM config
# Required when CONVERSATION_LLM_PROVIDER="openai-compatible"
# and USER_PROVIDER_KEYS_MODE is false
# Optional fallback when USER_PROVIDER_KEYS_MODE is true
# Ignored when USER_PROVIDER_KEYS_MODE is full
# Use a base URL such as https://api.openai.com/v1
# ------------------------------------------------------------
CONVERSATION_LLM_OPENAI_BASE_URL="https://api.openai.com/v1"
CONVERSATION_LLM_OPENAI_API_KEY="your_openai_compatible_api_key"
CONVERSATION_LLM_OPENAI_MODEL="gpt-4o-mini"

# ------------------------------------------------------------
# Platform default Deepgram key and STT options
# Required when USER_PROVIDER_KEYS_MODE is false
# Optional fallback when USER_PROVIDER_KEYS_MODE is true
# Ignored when USER_PROVIDER_KEYS_MODE is full
# ------------------------------------------------------------
DEEPGRAM_API_KEY="your_deepgram_api_key"
DEEPGRAM_MODEL="nova-2"
DEEPGRAM_LANGUAGE="zh"
DEEPGRAM_INTERIM_RESULTS="true"
DEEPGRAM_PUNCTUATE="true"
DEEPGRAM_SMART_FORMAT="true"
DEEPGRAM_ENDPOINTING="25"
DEEPGRAM_PROFANITY_FILTER="false"
DEEPGRAM_FILLER_WORDS="false"
DEEPGRAM_NUMERALS="false"
DEEPGRAM_DETECT_LANGUAGE="false"
DEEPGRAM_NO_DELAY="true"
DEEPGRAM_DIARIZE="false"
DEEPGRAM_DICTATION="false"
DEEPGRAM_SAMPLE_RATE="16000"
DEEPGRAM_NUM_CHANNELS="1"
DEEPGRAM_MIP_OPT_OUT="false"

# ------------------------------------------------------------
# App security
# ------------------------------------------------------------
APP_ENCRYPTION_SECRET="replace_with_a_random_32_plus_char_secret"
SESSION_TTL_HOURS="24"
